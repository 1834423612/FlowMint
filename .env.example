# FlowMint environment template
# Copy this file to .env for local development.

# Required: Prisma datasource (MySQL)
# Example:
# DATABASE_URL="mysql://root:password@127.0.0.1:3306/flowmint?connection_limit=10"
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/flowmint"

# Optional: Cloudflare R2 (required only when using screenshot/artifact upload)
# Use R2_ROOT_FOLDER to isolate this project when sharing one bucket across projects.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ROOT_FOLDER="flowmint"
R2_PUBLIC_BASE_URL=""

# Optional: Runtime/Debug
NODE_ENV="development"
DEBUG=""
